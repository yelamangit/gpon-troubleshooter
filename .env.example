# === NetDevOps Auto-Dispatcher — ШАБЛОН ===
# Скопируй: cp .env.example .env

API_TOKEN=your_api_token_here
OLT_USER=your_olt_login
OLT_PASS=your_olt_password

# Авто-логин в Саппорт-Центр (для обновления токена)
SC_USER=your_support_center_login
SC_PASS=your_support_center_password

# Telegram-бот
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# ID отдела L1 для возврата заявок при массовых авариях
# Узнать можно через API: GET /api/support/tickets/departments
L1_DEPT_ID=0

DRY_RUN=true
